{
    "crons": [
        {
            "path": "/api/cron/publish-scheduled",
            "schedule": "0 9 * * *"
        },
        {
            "path": "/api/cron/alerts",
            "schedule": "0 8 * * *"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}