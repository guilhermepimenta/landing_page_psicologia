{
    "crons": [
        {
            "path": "/api/cron/publish-scheduled",
            "schedule": "0 9 * * *"
        },
        {
            "path": "/api/cron/alerts",
            "schedule": "0 8 * * *"
        },
        {
            "path": "/api/cron/weekly-report",
            "schedule": "0 8 * * 1"
        }
    ],
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/assets/image.webp",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/index.html",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-cache, no-store, must-revalidate"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/api/instagram/publish",
            "destination": "/api/instagram"
        },
        {
            "source": "/api/cron/trigger",
            "destination": "/api/cron/publish-scheduled"
        },
        {
            "source": "/api/cron/alerts-trigger",
            "destination": "/api/cron/alerts"
        },
        {
            "source": "/api/cron/weekly-report-trigger",
            "destination": "/api/cron/weekly-report"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}