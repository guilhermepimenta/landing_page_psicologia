{
    "crons": [
        {
            "path": "/api/cron/publish-scheduled",
            "schedule": "0 9 * * *"
        },
        {
            "path": "/api/cron/alerts",
            "schedule": "0 8 * * *"
        },
        {
            "path": "/api/cron/weekly-report",
            "schedule": "0 8 * * 1"
        }
    ],
    "rewrites": [
        {
            "source": "/api/cron/trigger",
            "destination": "/api/cron/publish-scheduled"
        },
        {
            "source": "/api/cron/alerts-trigger",
            "destination": "/api/cron/alerts"
        },
        {
            "source": "/api/cron/weekly-report-trigger",
            "destination": "/api/cron/weekly-report"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}