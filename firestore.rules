rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Apenas usuários autenticados podem acessar o banco de dados
    // Como é uma aplicação de usuário único (Fernanda), qualquer usuário
    // autenticado tem acesso total às coleções.

    match /posts/{postId} {
      allow read, write: if request.auth != null;
    }

    match /metrics/{metricId} {
      allow read, write: if request.auth != null;
    }

    match /ideas/{ideaId} {
      allow read, write: if request.auth != null;
    }

    match /settings/{document} {
      allow read, write: if request.auth != null;
    }

    // Mensagens: qualquer visitante pode criar (landing page), somente autenticado lê/edita/exclui
    match /mensagens/{msgId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Alertas proativos: somente autenticado lê; escrita apenas pelo backend (admin SDK ignora regras)
    match /alerts/{alertId} {
      allow read: if request.auth != null;
      allow write: if false; // escrito exclusivamente pelo Firebase Admin SDK
    }

    // Logs de execução dos alertas: somente autenticado lê
    match /alerts_logs/{logId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Logs de envio dos relatórios semanais: somente autenticado lê
    match /weekly_reports_logs/{logId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Bloquear qualquer outra coleção não listada
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
