# Firebase Configuration
# Copie este arquivo para .env e preencha com suas credenciais reais do Firebase

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
# Use exatamente o valor de "Storage bucket" mostrado no Firebase Console
VITE_FIREBASE_STORAGE_BUCKET=fernanda-psicologia.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Gemini AI (Google)
# Obtenha sua chave em: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here
